{
  "name": "dynamic-tool-approval",
  "version": "1.0.0",
  "description": "Sample demonstrating dynamic user approval for tool use using Genkit.",
  "main": "src/server/index.ts",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx --env-file=.env --watch src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx --env-file=.env src/server/index.ts"
  },
  "type": "module",
  "dependencies": {
    "@genkit-ai/google-genai": "^1.36.0",
    "express": "^5.2.1",
    "genkit": "^1.36.0",
    "helmet": "^8.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
